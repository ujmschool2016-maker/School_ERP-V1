rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: students
    // Fields: id, roll, name, fatherName, motherName, address, mobile, dob, className, photo
    //
    // Collection: teachers
    // Fields: id, name, fatherName, address, mobile, dob, designation, joiningDate, baseSalary, photo
    //
    // Collection: rates
    // Fields: className, admissionFee, tuitionFee, examFee, sessionFee, registrationFee
    //
    // Collection: attendance
    // Fields: id, entityId, entityName, type, date, status, time, className
    //
    // Collection: fees
    // Fields: id, studentRoll, month, admissionFee, registrationFee, idCardDiaryFee, sessionFee, tuitionFee, examFee, culturalSportsFee, scholarshipExamFee, othersFee, previousDue, total, paidAmount, dueAmount
    //
    // Collection: results
    // Fields: id, studentRoll, className, examType, subject, marks, grade, status
    //
    // Collection: leaves
    // Fields: id, applicantId, applicantName, type, category, startDate, endDate, reason, status
    //
    // Collection: salaries
    // Fields: id, teacherId, month, baseSalary, bonus, deductions, total, paymentDate, status
    //
    // Collection: costs
    // Fields: id, category, description, amount, date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "datafusion611@gmail.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidNumber(val, min) {
      return val is number && val >= min;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidStudent(data) {
      return hasRequiredFields(['id', 'roll', 'name', 'className']) &&
             isValidString(data.name, 1, 100) &&
             isValidString(data.roll, 1, 20) &&
             isValidString(data.className, 1, 50);
    }

    function isValidTeacher(data) {
      return hasRequiredFields(['id', 'name', 'designation', 'baseSalary']) &&
             isValidString(data.name, 1, 100) &&
             isValidNumber(data.baseSalary, 0);
    }

    function isValidRate(data) {
      return hasRequiredFields(['className']) &&
             isValidString(data.className, 1, 50);
    }

    function isValidAttendance(data) {
      return hasRequiredFields(['id', 'entityId', 'type', 'date', 'status']) &&
             data.status in ['Present', 'Absent', 'Late'] &&
             data.type in ['Student', 'Teacher'];
    }

    function isValidFee(data) {
      return hasRequiredFields(['id', 'studentRoll', 'month', 'total', 'paidAmount']) &&
             isValidNumber(data.total, 0) &&
             isValidNumber(data.paidAmount, 0);
    }

    function isValidResult(data) {
      return hasRequiredFields(['id', 'studentRoll', 'className', 'examType', 'subject', 'marks']) &&
             data.examType in ['1st', '2nd', '3rd', 'Annual'] &&
             isValidNumber(data.marks, 0);
    }

    function isValidLeave(data) {
      return hasRequiredFields(['id', 'applicantId', 'type', 'startDate', 'endDate', 'status']) &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.type in ['Student', 'Teacher'];
    }

    function isValidSalary(data) {
      return hasRequiredFields(['id', 'teacherId', 'month', 'total', 'status']) &&
             data.status in ['Paid', 'Pending'] &&
             isValidNumber(data.total, 0);
    }

    function isValidCost(data) {
      return hasRequiredFields(['id', 'category', 'amount', 'date']) &&
             isValidNumber(data.amount, 0);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidStudent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidTeacher(request.resource.data);
      allow delete: if isAdmin();
    }

    match /rates/{rateId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidRate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAttendance(request.resource.data);
      allow delete: if isAdmin();
    }

    match /fees/{feeId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidFee(request.resource.data);
      allow delete: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidResult(request.resource.data);
      allow delete: if isAdmin();
    }

    match /leaves/{leaveId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidLeave(request.resource.data);
      allow delete: if isAdmin();
    }

    match /salaries/{salaryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidSalary(request.resource.data);
      allow delete: if isAdmin();
    }

    match /costs/{costId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidCost(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && !('role' in request.resource.data));
      allow delete: if isAdmin();
    }
  }
}
